# [1/5] GEMINI SCRIPT GENERATION (14 MINS MAX LIMIT)
def generate_script_from_gemini():
    print("[1/5] Querying Gemini API for high-retention finance topics...")
    
    SYSTEM_INSTRUCTION = """
You are a brilliant, slightly cynical, and highly sarcastic Gen Z financial analyst. 
Your goal is to write highly engaging, fast-paced scripts for YouTube. 
You absolutely hate traditional, boring, robotic "faceless slop" channels, and you refuse to write like them. 

Strict Writing Rules:
1. TONALITY: Conversational, witty, charismatic, and slightly sarcastic. Write exactly how a real human speaks—use short sentence fragments, dramatic pauses, and rhetorical questions. 
2. HOOK: Never start with "Welcome to Apex Wealth Lab" or "In this video, we will explore...". Start with a punchy, shocking, or deeply contrarian statement in the first 3 seconds. (e.g., "Congratulations, your high-yield savings account is officially a scam. Here's how the bank is using your money to buy yachts while giving you crumbs.")
3. LANGUAGE: Use natural Gen Z/modern internet slang where it fits naturally, but don't overdo it to the point of cringe. Think "rent-free", "side eye", "main character energy", "cooking", "mathematically cooked", or "bro really thought".
4. PACING: High retention. Every sentence must lead directly into the next. Use humor, dry wit, and visual metaphors instead of dry economic definitions. (Instead of "inflation reduces purchasing power," say "inflation is basically the government silently tax-evading your pocket money while you're asleep.")
5. CALL TO ACTION (CTA): Keep it subtle, brief, and clever. No begging for likes.
6. FORMAT: Return ONLY the raw spoken text. Do not include sound effect cues, scene descriptions, or slide directions (like "[SFX: Cash Register]" or "[Visual: Car]"). Just the pure, raw transcript to be fed directly into the text-to-speech engine.
"""

    # Pass system_instruction here when initializing the model, not inside generate_content!
    model = genai.GenerativeModel(
        model_name='gemini-2.5-flash',
        system_instruction=SYSTEM_INSTRUCTION
    )
    
    prompt = "Write a high-retention, engaging script about why traditional saving is a losing game and where smart money actually goes."

    try:
        # Keep this clean without system_instruction inside
        response = model.generate_content(
            prompt,
            generation_config={"response_mime_type": "text/plain"}
        )
        script_text = response.text
        with open("script.txt", "w", encoding="utf-8") as f:
            f.write(script_text)
        print(f"Success! Generated a script of {len(script_text.split())} words.")
        return script_text
    except Exception as e:
        print(f"Error generating script from Gemini: {e}")
        sys.exit(1)

# [2/5] ELEVENLABS VOICEOVER GENERATION
def generate_voiceover(output_path="voiceover.mp3"):
    print("[2/5] Synthesizing voiceover with ElevenLabs...")
    
    if not os.path.exists("script.txt"):
        print("Error: script.txt not found!")
        sys.exit(1)
        
    with open("script.txt", "r", encoding="utf-8") as f:
        text = f.read()

    # Grab keys securely from environment variables
    api_key = os.environ.get("ELEVENLABS_API_KEY")
    # Default to a crisp male/narrator voice (e.g., 'pNInz6obpg75e3OcAncf') if no custom voice ID is provided
    voice_id = os.environ.get("ELEVENLABS_VOICE_ID", "pNInz6obpg75e3OcAncf") 
    
    if not api_key:
        print("Error: ELEVENLABS_API_KEY environment variable is missing!")
        sys.exit(1)

    url = f"https://api.elevenlabs.io/v1/text-to-speech/{voice_id}"
    
    headers = {
        "Accept": "audio/mpeg",
        "Content-Type": "application/json",
        "xi-api-key": api_key
    }
    
    data = {
        "text": text,
        "model_id": "eleven_flash_v2",  # Ultra-fast, highly conversational, and light on API quotas
        "voice_settings": {
            "stability": 0.35,          # Low stability gives a more dramatic, conversational, and expressive performance
            "similarity_boost": 0.8,
            "style": 0.1,
            "use_speaker_boost": True
        }
    }
    
    try:
        response = requests.post(url, json=data, headers=headers)
        if response.status_code == 200:
            with open(output_path, "wb") as f:
                f.write(response.content)
            print("Success! voiceover.mp3 generated completely with ElevenLabs.")
            return output_path
        else:
            print(f"ElevenLabs Error: {response.status_code} - {response.text}")
            sys.exit(1)
    except Exception as e:
        print(f"Failed to connect to ElevenLabs API: {e}")
        sys.exit(1)

# [3/5] LUXURY FOOTAGE SCRAPER (DARK AESTHETIC EDITS)
def fetch_luxury_stock_footage():
    print("[3/5] Scraping dark luxury aesthetic clips from Pexels...")
    keywords = ["luxury lifestyle", "supercar night", "luxury watch", "yacht luxury", "mansion aesthetic", "rolls royce black"]
    headers = {"Authorization": PEXELS_API_KEY}
    video_urls = []
    
    for word in random.sample(keywords, 4):
        url = f"https://api.pexels.com/videos/search?query={word}&per_page=6&orientation=landscape"
        try:
            response = requests.get(url, headers=headers).json()
            for video in response.get("videos", []):
                video_files = video.get("video_files", [])
                if video_files:
                    optimal_files = [f for f in video_files if f.get("width", 0) <= 1920]
                    video_urls.append(optimal_files[0].get("link") if optimal_files else video_files[0].get("link"))
        except Exception as e:
            print(f"Error querying Pexels: {e}")

    os.makedirs("raw_clips", exist_ok=True)
    downloaded_paths = []
    
    for i, link in enumerate(video_urls[:15]):
        clip_path = f"raw_clips/clip_{i}.mp4"
        try:
            video_data = requests.get(link).content
            with open(clip_path, "wb") as file:
                file.write(video_data)
            downloaded_paths.append(clip_path)
        except Exception as e:
            print(f"Failed to download clip {i}")
            
    return downloaded_paths

# [4/5] MOVIEPY DYNAMIC RENDER ENGINE (FAST-PACED EDITING - OPTIMIZED)
def render_luxury_videos():
    print("[4/5] Initiating MoviePy Luxury Aesthetic Editor...")
    audio_path = "voiceover.mp3"
    
    if not os.path.exists(audio_path):
        print("Error: Voiceover file missing.")
        sys.exit(1)

    voiceover = AudioFileClip(audio_path)
    total_duration = voiceover.duration
    
    clip_files = [f"raw_clips/{f}" for f in os.listdir("raw_clips") if f.endswith(".mp4")]
    if not clip_files:
        print("Error: No downloaded clips found to compile.")
        sys.exit(1)
        
    print(f"Pre-loading {len(clip_files)} source clips into memory to prevent resource exhaustion...")
    loaded_videos = []
    for file in clip_files:
        try:
            loaded_videos.append(VideoFileClip(file))
        except Exception as e:
            print(f"Skipping unreadable clip {file}: {e}")

    if not loaded_videos:
        print("Error: Total failure loading source video clips.")
        sys.exit(1)

    processed_subclips = []
    current_time = 0
    
    print("Chopping clips into aggressive 2-second viral cuts with custom color grades...")
    while current_time < total_duration:
        random.shuffle(loaded_videos)
        for video in loaded_videos:
            if current_time >= total_duration:
                break
            try:
                # Snag a fast 2-second bite from a random starting point safely
                if video.duration > 2.5:
                    start_sec = random.uniform(0, video.duration - 2.5)
                else:
                    start_sec = 0
                
                # Slice and resize using pre-loaded memory reference
                subclip = video.subclip(start_sec, start_sec + 2.0).resize(newsize=(1920, 1080))
                
                # Apply a moody, rich dark luxury grade
                subclip = subclip.fx(vfx.colorx, 0.7)  
                
                processed_subclips.append(subclip)
                current_time += 2.0
            except Exception as e:
                print(f"Warning: Failed to slice clip segment: {e}")
                continue

    print("Stitching compilation track and linking audio...")
    full_video_track = concatenate_videoclips(processed_subclips, method="compose")
    final_longform = full_video_track.set_audio(voiceover).set_duration(total_duration)
    
    print("Encoding final long-form video...")
    final_longform.write_videofile("final_longform.mp4", fps=30, codec="libx264", preset="ultrafast")
    
    print("Generating the center-cropped vertical 35-second viral Short...")
    short_clip = final_longform.subclip(60, 95).crop(x_center=960, y_center=540, width=607, height=1080).resize(newsize=(720, 1280))
    short_clip.write_videofile("final_short.mp4", fps=30, codec="libx264", preset="ultrafast")
    
    # Close resources cleanly to clear runner RAM
    print("Cleaning up video handles...")
    for v in loaded_videos:
        v.close()
    voiceover.close()
    
    print("Success! Luxury-grade video assets compiled completely.")

# [5/5] YOUTUBE UPLOADER ENGINE (CLEAN DESCRIPTION - NO LINKS)
def upload_to_youtube():
    print("[5/5] Authorizing via OAuth 2.0 and uploading to YouTube...")
    from googleapiclient.discovery import build
    from googleapiclient.http import MediaFileUpload
    from google.oauth2.credentials import Credentials
    
    refresh_token = os.environ.get("YOUTUBE_REFRESH_TOKEN")
    client_id = os.environ.get("YOUTUBE_CLIENT_ID")
    client_secret = os.environ.get("YOUTUBE_CLIENT_SECRET")
    
    creds = Credentials(
        token=None,
        refresh_token=refresh_token,
        token_uri="https://oauth2.googleapis.com/token",
        client_id=client_id,
        client_secret=client_secret
    )
    
    try:
        youtube = build("youtube", "v3", credentials=creds)
        
        # Clean, focus-driven descriptions
        longform_description = (
            "Discover advanced wealth creation frameworks, financial intelligence, and macroeconomic shifts.\n\n"
            "Welcome to Apex Wealth Lab. We decode the hidden systems behind global markets.\n\n"
            "#finance #wealth #macroeconomics #financialfreedom"
        )
        
        shorts_description = "The hidden reality of asset allocation. #finance #wealth #shorts"
        
        if os.path.exists("final_longform.mp4"):
            print("Uploading long-form video...")
            longform_body = {
                "snippet": {
                    "title": "The Hidden Financial System Exploited by the 1% (Masterclass)",
                    "description": longform_description,
                    "categoryId": "27"
                },
                "status": {
                    "privacyStatus": "public",
                    "selfDeclaredMadeForKids": False
                }
            }
            media_long = MediaFileUpload("final_longform.mp4", chunksize=-1, resumable=True)
            request_long = youtube.videos().insert(part="snippet,status", body=longform_body, media_body=media_long)
            response_long = request_long.execute()
            print(f"Success! Long-form uploaded. Video ID: {response_long.get('id')}")
            
        if os.path.exists("final_short.mp4"):
            print("Uploading viral vertical Short...")
            short_body = {
                "snippet": {
                    "title": "The fastest way to build wealth in 2026 💸 #shorts #finance",
                    "description": shorts_description,
                    "categoryId": "27"
                },
                "status": {
                    "privacyStatus": "public",
                    "selfDeclaredMadeForKids": False
                }
            }
            media_short = MediaFileUpload("final_short.mp4", chunksize=-1, resumable=True)
            request_short = youtube.videos().insert(part="snippet,status", body=short_body, media_body=media_short)
            response_short = request_short.execute()
            print(f"Success! Shorts uploaded. Video ID: {response_short.get('id')}")
            
    except Exception as e:
        print(f"An error occurred during YouTube upload execution: {e}")
        sys.exit(1)

